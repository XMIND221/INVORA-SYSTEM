{
  "name": "invora-v2",
  "private": true,
  "version": "2.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx}\" \"supabase/**/*.{ts,sql}\" \"*.{md,json}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx}\" \"supabase/**/*.{ts,sql}\" \"*.{md,json}\"",
    "typecheck": "tsc -b --noEmit",
    "test:phase10": "node scripts/phase10-engine-tests.mjs",
    "test:phase11a": "node scripts/phase11a-engine-tests.mjs",
    "test:phase11b": "node scripts/phase11b-engine-tests.mjs",
    "test:phase11d": "node scripts/phase11d-engine-tests.mjs",
    "test:phase11e": "node scripts/phase11e-engine-tests.mjs",
    "test:phase11f": "node scripts/phase11f-engine-tests.mjs",
    "notifications:dispatch": "node scripts/invoke-notification-dispatch.mjs",
    "supabase": "supabase",
    "supabase:login": "supabase login",
    "supabase:link": "supabase link --project-ref njucvyxucacgiztaczkn",
    "supabase:db:push": "supabase db push",
    "supabase:functions:deploy": "supabase functions deploy validate-scan && supabase functions deploy audit-log && supabase functions deploy calculate-pricing && supabase functions deploy process-ticket-purchase && supabase functions deploy calculate-partner-commission && supabase functions deploy scanner-validate-access && supabase functions deploy calculate-finance-quote && supabase functions deploy payment-initiate && supabase functions deploy payment-webhook-processor && supabase functions deploy payment-simulate-confirm && supabase functions deploy notification-dispatch",
    "supabase:deploy": "npm run supabase:db:push && npm run supabase:functions:deploy && npm run supabase:types",
    "deploy:backend": "npm run supabase:deploy",
    "supabase:types": "supabase gen types typescript --linked > src/types/database.generated.ts",
    "supabase:types:remote": "supabase gen types typescript --project-id njucvyxucacgiztaczkn > src/types/database.generated.ts"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.49.1",
    "@tanstack/react-query": "^5.66.0",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "framer-motion": "^12.4.7",
    "html5-qrcode": "^2.3.8",
    "lucide-react": "^0.475.0",
    "qrcode": "^1.5.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.54.2",
    "react-router-dom": "^7.2.0",
    "recharts": "^2.15.1",
    "sonner": "^2.0.1",
    "tailwind-merge": "^3.0.1",
    "zod": "^3.24.2",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.20.0",
    "@tailwindcss/vite": "^4.2.1",
    "@types/node": "^22.13.4",
    "@types/qrcode": "^1.5.5",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@vitejs/plugin-react": "^4.3.4",
    "dotenv": "^17.4.2",
    "eslint": "^9.20.1",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "globals": "^15.15.0",
    "pg": "^8.21.0",
    "prettier": "^3.5.1",
    "supabase": "^2.102.0",
    "tailwindcss": "^4.2.1",
    "tw-animate-css": "^1.3.4",
    "typescript": "~5.7.3",
    "typescript-eslint": "^8.24.0",
    "vite": "^6.1.0"
  }
